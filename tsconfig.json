{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": "./",
    "paths": {
      "~/*": ["./*"],
      "~/": ["./"],
      "@/*": ["./*"],
      "@@/*": ["./*"]
    },
    "types": ["node"]
  },
  "exclude": ["node_modules", ".nuxt", "dist"]
}
